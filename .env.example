# Local development only. Do not set NEXT_PUBLIC_API_BASE_URL on Vercel full-stack deploys
# unless you intentionally want the frontend to call an external backend.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Fill your real values in .env. Do not commit secrets.
DASHSCOPE_API_KEY=<your-dashscope-api-key>
BAILIAN_APP_ID=<your-bailian-app-id>
DASHSCOPE_MODEL_NAME=qwen-plus
DASHSCOPE_VISION_MODEL=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

ENABLE_CLOUD_SYNC=false
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
DASHSCOPE_WORKSPACE_ID=<optional-workspace-id>
BAILIAN_ENDPOINT=bailian.cn-beijing.aliyuncs.com
BAILIAN_DOCS_KB_ID=<your-docs-kb-id>
BAILIAN_FAQ_KB_ID=<optional-faq-kb-id>

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
